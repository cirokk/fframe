# Copie para .env e ajuste. Nada aqui tem valor secreto por padrão —
# os segredos reais (senha de admin, device keys, session secret) são
# gerados e guardados em runtime dentro de data/, nunca neste arquivo.

# Porta publicada no host
PORT=3260

# Endereço público deste servidor (usado nas upload_urls do fluxo FiLMiC
# e no QR code de pareamento de dispositivos). Em produção, use o domínio
# real por trás do seu proxy/túnel, ex.: https://videos.seudominio.com
PUBLIC_BASE=http://localhost:3260

# Onde os vídeos e dados ficam salvos no host
DATA_DIR=./data

# Nome do container
CONTAINER_NAME=fframe-server

# Tamanho de cada pedaço de upload (bytes). 25MB por padrão.
CHUNK_SIZE=26214400
