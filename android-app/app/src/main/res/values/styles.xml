<resources>
    <style name="Label">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="Field">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/field_bg</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="android:padding">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_marginBottom">18dp</item>
    </style>

    <style name="Radio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:buttonTint">@color/royal</item>
    </style>

    <style name="Primary">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/btn_primary</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">14dp</item>
    </style>

    <style name="Ghost">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="ModeBtn">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/btn_ghost</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingHorizontal">2dp</item>
        <item name="android:paddingVertical">13dp</item>
        <item name="android:maxLines">1</item>
    </style>
</resources>
