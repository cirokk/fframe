<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:elevation="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Novo vídeo gravado"
            android:textColor="@color/ink"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/askName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/muted"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="middle"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="18dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/askIgnore" style="@style/ModeBtn"
                android:layout_marginEnd="6dp" android:text="Ignorar" />
            <Button android:id="@+id/askQueue" style="@style/ModeBtn"
                android:layout_marginHorizontal="6dp" android:text="Fila" />
            <Button android:id="@+id/askSend" style="@style/ModeBtn"
                android:layout_marginStart="6dp" android:text="Enviar"
                android:background="@drawable/btn_primary" android:textColor="@color/ink" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
