# Copie para keystore.properties (NUNCA versione o real) e preencha com a sua
# chave de assinatura. Sem esse arquivo, o gradlew assembleRelease ainda
# funciona, mas gera um APK sem assinatura de release.
#
# Gerar uma chave nova:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias fframe

storeFile=release.jks
storePassword=troque-esta-senha
keyAlias=fframe
keyPassword=troque-esta-senha
